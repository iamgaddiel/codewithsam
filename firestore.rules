rules_version = '2';

// Security rules for the CodeWithSammy website.
//
// Auth model: only the site ADMIN has an account. Students never sign in.
//
//   * Registrations are written ONLY by the Paystack webhook (a Netlify
//     serverless function using the Firebase Admin SDK, which bypasses these
//     rules). It writes a record only after verifying the payment directly
//     with Paystack, so a browser can never forge a "paid" registration.
//   * The admin (signed in) may read, update and delete registrations and
//     edit the site settings (pricing + cohort) in the `config` collection.
//   * The public site may READ `config` (to render pricing/cohort) but has no
//     other access to Firestore.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Admin identity -------------------------------------------------
    // Create the admin account in Firebase Console -> Authentication, then
    // paste its UID(s) below (Authentication -> Users -> "User UID").
    // Add more UIDs to the list to grant additional admins.
    function isAdmin() {
      return request.auth != null
          && request.auth.uid in [
               'PASTE_ADMIN_UID_HERE'
             ];
    }

    match /registrations/{regId} {
      // Only the admin can read or delete registrations.
      allow read, delete: if isAdmin();

      // TEMPORARY (webhook bypass): the confirmation page (success.html) writes
      // the paid registration client-side after the payment is verified. The
      // document id must equal the payment reference, and the record must look
      // like a paid registration. NOTE: this is spoofable by a determined user
      // (a browser can write a fake "paid" record) — remove it and rely on the
      // webhook once the webhook is working.
      allow create, update: if isAdmin() || (
        request.resource.data.status == 'paid'
        && request.resource.data.paymentRef == regId
        && request.resource.data.email is string
        && request.resource.data.amount is number
      );
    }

    // Site settings (pricing table, benefits, current cohort + dates).
    // The public site reads this to render; only the admin can change it.
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Everything else is closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
