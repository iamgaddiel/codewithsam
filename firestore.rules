rules_version = '2';

// Security rules for the CodeWithSammy website.
//
// Auth model: only the site ADMIN has an account. Students never sign in.
//
//   * Registrations are written ONLY by the Paystack webhook Cloud Function,
//     which uses the Firebase Admin SDK and bypasses these rules. It writes a
//     record only after verifying the payment directly with Paystack, so a
//     browser can never forge a "paid" registration.
//   * The admin (signed in) may read, update and delete registrations.
//   * The public/anonymous client has no access to Firestore at all.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Admin identity -------------------------------------------------
    // Create the admin account in Firebase Console -> Authentication, then
    // paste its UID(s) below (Authentication -> Users -> "User UID").
    // Add more UIDs to the list to grant additional admins.
    function isAdmin() {
      return request.auth != null
          && request.auth.uid in [
               'PASTE_ADMIN_UID_HERE'
             ];
    }

    match /registrations/{regId} {
      // Registrations are created only by the Paystack webhook (Admin SDK,
      // which bypasses these rules). Clients get no write access here.
      allow read, update, delete: if isAdmin();
    }

    // Everything else is closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
