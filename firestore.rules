rules_version = '2';

// Security rules for the CodeWithSammy website.
//
// Auth model: only the site ADMIN has an account. Students never sign in —
// they submit the public registration form (index.html) anonymously.
//
//   * Anonymous visitors  -> may ONLY create a registration (validated).
//   * The admin (signed in) -> may read, update and delete registrations.
//
// Paid status is NOT set by the anonymous client (that would be spoofable
// and students have no account to scope an update to). Instead, mark a
// registration "paid" either from an admin tool, or — recommended — from a
// Paystack webhook running with the Firebase Admin SDK, which bypasses these
// rules entirely.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Admin identity -------------------------------------------------
    // Create the admin account in Firebase Console -> Authentication, then
    // paste its UID(s) below (Authentication -> Users -> "User UID").
    // Add more UIDs to the list to grant additional admins.
    function isAdmin() {
      return request.auth != null
          && request.auth.uid in [
               'PASTE_ADMIN_UID_HERE'
             ];
    }

    // ---- Validation for a new public registration -----------------------
    function isValidRegistration(data) {
      return data.keys().hasOnly(['fullName', 'email', 'phone', 'track', 'plan', 'amount', 'status', 'createdAt'])
          && data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 120
          && data.email is string && data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
          && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 40
          && data.track is string && data.track.size() <= 80
          && data.plan is string && data.plan.size() <= 40
          && data.amount is number && data.amount >= 0
          && data.status == 'pending'
          && data.createdAt is timestamp;
    }

    match /registrations/{regId} {
      // Anyone can submit a registration — no account required.
      allow create: if isValidRegistration(request.resource.data);

      // Only the admin can view, edit or remove registrations.
      allow read, update, delete: if isAdmin();
    }

    // Everything else is closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
